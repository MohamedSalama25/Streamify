PORT=4000
CLIENT_URL=http://localhost:3000
RTC_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
# TURN is required for reliable calls across different networks/NATs (production).
# Example (coturn):
# RTC_TURN_URLS=turn:YOUR_DOMAIN_OR_IP:3478?transport=udp,turn:YOUR_DOMAIN_OR_IP:3478?transport=tcp,turns:YOUR_DOMAIN_OR_IP:5349?transport=tcp
RTC_TURN_URLS=
RTC_TURN_USERNAME=
RTC_TURN_CREDENTIAL=
# In production defaults to true if not set.
RTC_REQUIRE_TURN=
# Optional: "relay" forces TURN-only (more reliable in restrictive networks), "all" (default).
RTC_ICE_TRANSPORT_POLICY=
